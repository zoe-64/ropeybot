{
    "name": "ropeybot",
    "license": "Apache-2.0",
    "private": "true",
    "scripts": {
        "types": "tsc",
        "prettier": "prettier -c .",
        "compile:bc-bot": "cd src && npm run compile",
        "bundle": "npm run compile:bc-bot && esbuild bin/main.ts --bundle --platform=node --outfile=dist/bundle.js --sourcemap",
        "start": "npm run compile:bc-bot && tsx bin/main.ts",
        "docker": "pnpm run bundle && docker build -t ropeybot --no-cache ."
    },
    "dependencies": {
        "bc-bot": "link:src",
        "bc-stubs": "126.0.0",
        "lodash": "^4.17.23",
        "lz-string": "^1.5.0",
        "mongodb": "^6.21.0",
        "prettier": "^3.8.1",
        "prom-client": "^14.2.0"
    },
    "devDependencies": {
        "@tsconfig/node18": "^18.2.6",
        "@types/lodash": "^4.17.24",
        "@types/node": "^20.19.37",
        "esbuild": "^0.19.12",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3"
    }
}
